assert:
  $function:
    input: $bool
  return: $void
  do:
    - $wasm:
        import:
          module: vibra_test
          name: assert
        args:
          - $args.input

fail:
  $function:
    input: $str
  return: $void
  do:
    - $wasm:
        import:
          module: vibra_test
          name: fail
        args:
          - $args.input
