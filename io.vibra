fs:
  $import: ./fs.vibra
security:
  $import: ./security.vibra

stdin:
  $function: $void
  grants:
    stdin-read: $security.grant.mandatory
  return: $fs.read-file
  do:
    - $return:
        $cast: 0
        into: $fs.read-file

stdout:
  $function: $void
  return: $fs.write-file
  do:
    - $return:
        $cast: 1
        into: $fs.write-file

stderr:
  $function: $void
  return: $fs.write-file
  do:
    - $return:
        $cast: 2
        into: $fs.write-file

print:
  $function:
    input: $str
  return:
    $result.result:
      t: $void
      e: $fs.fs-error
  do:
    - $let:
        out:
          $io.stdout: null
    - $let:
        result:
          $fs.writable.write-string: $out
          s: $args.input
    - $return: $result

println:
  $function:
    input: $str
  return:
    $result.result:
      t: $void
      e: $fs.fs-error
  do:
    - $let:
        first:
          $io.print: $args.input
    - $let:
        second:
          $io.print: "\n"
    - $return: $second

eprint:
  $function:
    input: $str
  return:
    $result.result:
      t: $void
      e: $fs.fs-error
  do:
    - $let:
        err:
          $io.stderr: null
    - $let:
        result:
          $fs.writable.write-string: $err
          s: $args.input
    - $return: $result

eprintln:
  $function:
    input: $str
  return:
    $result.result:
      t: $void
      e: $fs.fs-error
  do:
    - $let:
        first:
          $io.eprint: $args.input
    - $let:
        second:
          $io.eprint: "\n"
    - $return: $second

readln:
  $function: $void
  grants:
    stdin-read: $security.grant.mandatory
  return:
    $result.result:
      t: $str
      e: $fs.fs-error
  do:
    - $let:
        input:
          $io.stdin: null
          =grants:
            - $grants.stdin-read
    - $let:
        result:
          $fs.readable.read-string: $input
    - $return: $result

flush:
  $function: $void
  return:
    $result.result:
      t: $void
      e: $fs.fs-error
  do:
    - $let:
        out:
          $io.stdout: null
    - $let:
        result:
          $fs.writable.flush: $out
    - $return: $result
