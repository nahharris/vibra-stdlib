security:
  $import: ./security.vibra

bytes-lib:
  $import: ./bytes.vibra

bytes:
  $function:
    input: $uint64
  grants:
    random: $security.grant.mandatory
  return: $bytes-lib.bytes
  do:
    - $wasm:
        import:
          module: wasi_snapshot_preview1
          name: random_get
        args:
          - $args.input
