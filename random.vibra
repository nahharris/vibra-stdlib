security:
  $import: ./security.vibra

bytes-lib:
  $import: ./bytes.vibra

bytes:
  $function: $uint64
  args:
    grant: $security.random-grant
  return: $bytes-lib.bytes
  do:
    - $wasm:
        import:
          module: wasi_snapshot_preview1
          name: random_get
        args:
          - $args.subject
          - $args.grant
