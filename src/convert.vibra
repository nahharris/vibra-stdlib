format-float64:
  $function:
    value: $float64
  return: $str
  do:
  - $wasm:
      import:
        module: vibra_v1
        name: format_float64
      args:
      - $args.value
format-bool:
  $function:
    value: $bool
  return: $str
  do:
  - $wasm:
      import:
        module: vibra_v1
        name: format_bool
      args:
