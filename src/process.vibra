result:
  $import: ./result.vibra
process-error:
  $enum:
    permission-denied: $void
    unsupported: $str
run-capability:
  $capability.process-run: null
run:
  $function:
    input: $str
  args:
    capability: $run-capability
  return:
    $result.result:
      t: $void
      e: $process-error
  do:
  - $wasm:
      import:
        module: vibra_v1
        name: process_run
      args:
      - $args.input
      - $args.capability
