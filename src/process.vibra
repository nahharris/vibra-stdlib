security:
  $import: ./security.vibra

result:
  $import: ./result.vibra

process-error:
  $enum:
    permission-denied: $void
    unsupported: $str

run:
  $function:
    input: $str
  grants:
    process-run: $security.grant.mandatory
  return:
    $result.result:
      t: $void
      e: $process-error
  do:
    - $wasm:
        import:
          module: vibra_v1
          name: process_run
        args:
          - $args.input
