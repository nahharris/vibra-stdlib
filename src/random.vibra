bytes-lib:
  $import: ./bytes.vibra
capability:
  $capability.random: null
bytes:
  $function:
    input: $uint64
  args:
    capability: $capability
  return: $bytes-lib.bytes
  do:
  - $wasm:
      import:
        module: vibra_v1
        name: random_bytes
      args:
      - $args.input
      - $args.capability
