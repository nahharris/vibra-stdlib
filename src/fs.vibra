open-read:
  $function:
    input: $path
  args:
    capability: $read-capability
  return:
    $result.result:
      t: $read-file
      e: $fs-error
  do:
  - $wasm:
      import:
        module: vibra_v1
        name: fs_open_read
      args:
      - $args.input
      - $args.capability
open-write:
  $function:
    input: $path
  args:
    capability: $write-capability
  return:
    $result.result:
      t: $write-file
