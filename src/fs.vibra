bytes-lib:
  $import: ./bytes.vibra
result:
  $import: ./result.vibra
option:
  $import: ./option.vibra
error-lib:
  $import: ./error.vibra
error:
  $import: ./error.vibra
path:
  $newtype: $str
  =defs:
    new:
      $function:
        input: $str
      return: $self
      do:
      - $wasm:
          import:
            module: vibra_v1
            name: path_new
          args:
          - $args.input
    join:
      $function: $self
      args:
        segment: $str
      return: $self
      do:
      - $wasm:
          import:
            module: vibra_v1
            name: path_join
          args:
          - $args.self
          - $args.segment
    parent:
      $function: $self
      return:
        $option.option:
          t: $self
      do:
      - $wasm:
          import:
            module: vibra_v1
            name: path_parent
          args:
          - $args.self
    extension:
      $function: $self
      return:
        $option.option:
          t: $str
      do:
      - $wasm:
          import:
            module: vibra_v1
            name: path_extension
          args:
          - $args.self
    file-name:
      $function: $self
      return:
        $option.option:
          t: $str
      do:
      - $wasm:
          import:
            module: vibra_v1
            name: path_file_name
          args:
          - $args.self
    components:
      $function: $self
      return:
        $result.result:
          t:
            $array: $str
          e: $fs-error
      do:
      - $wasm:
          import:
            module: vibra_v1
            name: path_components
          args:
          - $args.self
fs-error:
  $enum:
    not-found: $void
    permission-denied: $void
    already-exists: $void
    is-dir: $void
    not-dir: $void
    invalid-path: $void
    invalid-handle: $void
    resource-closed: $void
    too-many-open-files: $void
    io: $str
    limit-exceeded: $void
  =impl:
    $error.error:
      kind:
        $function: $self
        return: $error-lib.error-kind
        do:
        - $match: $args.self
          when:
          - case:
              $fs-error.not-found: null
            do:
            - $return:
                $error-lib.error-kind.not-found: null
          - case:
              $fs-error.permission-denied: null
            do:
            - $return:
                $error-lib.error-kind.permission-denied: null
          - case:
              $fs-error.already-exists: null
            do:
            - $return:
                $error-lib.error-kind.already-exists: null
          - case:
              $fs-error.invalid-path: null
            do:
            - $return:
                $error-lib.error-kind.invalid-input: null
          - case:
              $fs-error.resource-closed: null
            do:
            - $return:
                $error-lib.error-kind.resource-closed: null
          - case:
              $fs-error.too-many-open-files: null
            do:
            - $return:
                $error-lib.error-kind.resource-exhausted: null
          - case:
              $fs-error.limit-exceeded: null
            do:
            - $return:
                $error-lib.error-kind.resource-exhausted: null
          - case:
              $wildcard: null
            do:
            - $return:
                $error-lib.error-kind.io: null
      display:
        $function: $self
        return: $str
        do:
        - $match: $args.self
          when:
          - case:
              $fs-error.io:
                $bind: message
            do:
            - $return: $message
          - case:
              $wildcard: null
            do:
            - $return: filesystem operation failed
      context:
        $function: $self
        return:
          $option.option:
            t: $error-lib.context
        do:
        - $return:
            $option.option.some:
              $error-lib.make-context:
                kind:
                  $error-lib.error-kind.other: null
                operation: filesystem
                message: filesystem operation failed
                source:
                  $error-lib.no-source: null
error-kind:
  $function:
    input: $fs-error
  return: $error-lib.error-kind
  do:
  - $return:
      $error.error.kind: $args.input
read-capability:
  $capability.fs-read: null
write-capability:
  $capability.fs-write: null
directory-entry:
  $record:
    path: $path
    name: $str
    is-dir: $bool
    size: $uint64
readable:
  $interface:
    read-string:
      $fn-type:
        args:
          $record:
            self: $self
        return:
          $result.result:
            t: $str
            e: $fs-error
    read-bytes:
      $fn-type:
        args:
          $record:
            self: $self
        return:
          $result.result:
            t: $bytes-lib.bytes
            e: $fs-error
    read-bytes-up-to:
      $fn-type:
        args:
          $record:
            self: $self
            limit: $uint64
        return:
          $result.result:
            t: $bytes-lib.bytes
            e: $fs-error
    read-line:
      $fn-type:
        args:
          $record:
            self: $self
        return:
          $result.result:
            t: $str
            e: $fs-error
writable:
  $interface:
    write-string:
      $fn-type:
        args:
          $record:
            self: $self
            s: $str
        return:
          $result.result:
            t: $void
            e: $fs-error
    write-bytes:
      $fn-type:
        args:
          $record:
            self: $self
            b: $bytes-lib.bytes
        return:
          $result.result:
            t: $void
            e: $fs-error
    write-bytes-some:
      $fn-type:
        args:
          $record:
            self: $self
            b: $bytes-lib.bytes
        return:
          $result.result:
            t: $uint64
            e: $fs-error
    flush:
      $fn-type:
        args:
          $record:
            self: $self
        return:
          $result.result:
            t: $void
            e: $fs-error
appendable:
  $interface:
    append-string:
      $fn-type:
        args:
          $record:
            self: $self
            s: $str
        return:
          $result.result:
            t: $void
            e: $fs-error
    append-bytes:
      $fn-type:
        args:
          $record:
            self: $self
            b: $bytes-lib.bytes
        return:
          $result.result:
            t: $void
            e: $fs-error
closeable:
  $interface:
    close:
      $fn-type:
        args:
          $record:
            self: $self
        return:
          $result.result:
            t: $void
            e: $fs-error
read-file:
  $handle.read: null
  =impl:
    $readable:
      read-string:
        $function: $self
        return:
          $result.result:
            t: $str
            e: $fs-error
        do:
        - $wasm:
            import:
              module: vibra_v1
              name: fd_read
            args:
            - $args.self
      read-bytes:
        $function: $self
        return:
          $result.result:
            t: $bytes-lib.bytes
            e: $fs-error
        do:
        - $wasm:
            import:
              module: vibra_v1
              name: fd_read_bytes
            args:
            - $args.self
      read-bytes-up-to:
        $function: $self
        args:
          limit: $uint64
        return:
          $result.result:
            t: $bytes-lib.bytes
            e: $fs-error
        do:
        - $wasm:
