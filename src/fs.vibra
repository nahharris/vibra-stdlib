        do:
        - $wasm:
            import:
              module: vibra_v1
              name: fd_read_line
            args:
            - $args.self
    $closeable:
      close:
        $function: $self
        return:
          $result.result:
            t: $void
            e: $fs-error
        do:
        - $wasm:
            import:
              module: vibra_v1
              name: fd_close
            args:
            - $args.self
write-file:
  $handle.write: null
  =impl:
    $writable:
      write-string:
        $function: $self
        args:
          s: $str
        return:
          $result.result:
            t: $void
            e: $fs-error
        do:
        - $wasm:
            import:
              module: vibra_v1
              name: fd_write
            args:
            - $args.self
            - $args.s
      write-bytes:
        $function: $self
        args:
