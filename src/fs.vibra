            args:
            - $args.self
            - $args.b
      write-bytes-some:
        $function: $self
        args:
          b: $bytes-lib.bytes
        return:
          $result.result:
            t: $uint64
            e: $fs-error
        do:
        - $wasm:
            import:
              module: vibra_v1
              name: fd_write_bytes_some
            args:
            - $args.self
            - $args.b
      flush:
        $function: $self
        return:
          $result.result:
            t: $void
            e: $fs-error
        do:
        - $wasm:
            import:
              module: vibra_v1
              name: fd_sync
            args:
            - $args.self
    $closeable:
      close:
        $function: $self
        return:
          $result.result:
            t: $void
            e: $fs-error
        do:
        - $wasm:
            import:
              module: vibra_v1
              name: fd_close
            args:
