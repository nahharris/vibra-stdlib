option:
  $import: ./option.vibra
error-kind:
  $enum:
    not-found: $void
    permission-denied: $void
    already-exists: $void
    invalid-input: $void
    resource-closed: $void
    resource-exhausted: $void
    unavailable: $void
    unsupported: $void
    io: $void
    other: $void
context:
  $record:
    kind: $error-kind
    operation: $str
    message: $str
    source:
      $option.option:
        t: $str
no-source:
  $function: $void
  return:
    $option.option:
      t: $str
  do:
  - $return:
      $option.empty:
        t: $str
        ignored: false
make-context:
  $function:
    kind: $error-kind
  args:
    operation: $str
    message: $str
    source:
      $option.option:
        t: $str
  return: $context
  do:
  - $return:
      $record:
        kind: $args.kind
        operation: $args.operation
        message: $args.message
        source: $args.source
error:
  $interface:
    kind:
      $fn-type:
        args:
          $record:
            self: $self
        return: $error-kind
    display:
      $fn-type:
        args:
          $record:
            self: $self
        return: $str
    context:
      $fn-type:
        args:
          $record:
            self: $self
        return:
          $option.option:
            t: $context
