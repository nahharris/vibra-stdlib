              e: $fs-error
          do:
            - $wasm:
                import:
                  module: wasi_snapshot_preview1
                  name: fd_write
                args:
                  - $args.self
                  - $args.b
      flush:
        $function:
          args:
            self: $self
          return:
            $result.result:
              t: $void
              e: $fs-error
          do:
            - $wasm:
                import:
                  module: wasi_snapshot_preview1
                  name: fd_sync
                args:
                  - $args.self
    $appendable:
      append-string:
        $function:
          args:
            self: $self
            s: $str
          return:
            $result.result:
              t: $void
              e: $fs-error
          do:
            - $wasm:
                import:
                  module: wasi_snapshot_preview1
                  name: fd_write
                args:
                  - $args.self
                  - $args.s
      append-bytes:
        $function:
          args:
            self: $self
            b: $bytes-lib.bytes
          return:
            $result.result:
              t: $void
              e: $fs-error
          do:
            - $wasm:
                import:
                  module: wasi_snapshot_preview1
                  name: fd_write
                args:
                  - $args.self
                  - $args.b
    $closeable:
      close:
        $function:
          args:
            self: $self
          return:
            $result.result:
              t: $void
              e: $fs-error
          do:
            - $wasm:
                import:
                  module: wasi_snapshot_preview1
                  name: fd_close
                args:
                  - $args.self

read-write-file:
  $newtype: $uint64
  =impl:
    $readable:
      read-string:
        $function:
          args:
            self: $self
          return:
            $result.result:
              t: $str
              e: $fs-error
          do:
            - $wasm:
                import:
                  module: wasi_snapshot_preview1
                  name: fd_read
                args:
                  - $args.self
      read-bytes:
        $function:
          args:
            self: $self
          return:
            $result.result:
              t: $bytes-lib.bytes
              e: $fs-error
          do:
            - $wasm:
                import:
                  module: wasi_snapshot_preview1
                  name: fd_read
                args:
                  - $args.self
    $writable:
      write-string:
        $function:
          args:
            self: $self
            s: $str
          return:
            $result.result:
              t: $void
              e: $fs-error
          do:
            - $wasm:
                import:
                  module: wasi_snapshot_preview1
                  name: fd_write
                args:
                  - $args.self
                  - $args.s
      write-bytes:
        $function:
          args:
            self: $self
            b: $bytes-lib.bytes
          return:
            $result.result:
              t: $void
              e: $fs-error
          do:
            - $wasm:
                import:
                  module: wasi_snapshot_preview1
                  name: fd_write
                args:
                  - $args.self
                  - $args.b
      flush:
        $function:
          args:
            self: $self
          return:
            $result.result:
              t: $void
              e: $fs-error
          do:
            - $wasm:
                import:
                  module: wasi_snapshot_preview1
                  name: fd_sync
                args:
                  - $args.self
    $closeable:
      close:
        $function:
          args:
            self: $self
          return:
            $result.result:
              t: $void
