bytes-lib:
  $import: ./bytes.vibra

result:
  $import: ./result.vibra

security:
  $import: ./security.vibra

path:
  $newtype: $str
  =defs:
    new:
      $function:
        args:
          s: $str
        return: $self
        do:
          - $wasm:
              import:
                module: wasi_snapshot_preview1
                name: path_new
              args:
                - $args.s
    join:
      $function:
        args:
          self: $self
          segment: $str
        return: $self
        do:
          - $wasm:
              import:
                module: wasi_snapshot_preview1
                name: path_join
              args:
                - $args.self
                - $args.segment
    parent:
      $function:
        args:
          self: $self
        return:
          $option: $self
        do:
          - $wasm:
              import:
                module: wasi_snapshot_preview1
                name: path_parent
              args:
                - $args.self
    extension:
      $function:
        args:
          self: $self
        return:
          $option: $str
        do:
          - $wasm:
              import:
                module: wasi_snapshot_preview1
                name: path_extension
              args:
                - $args.self

fs-error:
  $enum:
    not-found: $void
    permission-denied: $void
    already-exists: $void
    is-dir: $void
    not-dir: $void
    invalid-path: $void
    io: $str

readable:
  $interface:
    read-string:
      $fn-type:
        args:
          $record:
            self: $self
        return:
          $result.result:
            t: $str
            e: $fs-error
    read-bytes:
      $fn-type:
        args:
          $record:
            self: $self
        return:
          $result.result:
            t: $bytes-lib.bytes
            e: $fs-error

writable:
  $interface:
    write-string:
      $fn-type:
        args:
          $record:
            self: $self
            s: $str
        return:
          $result.result:
            t: $void
            e: $fs-error
    write-bytes:
      $fn-type:
        args:
          $record:
            self: $self
            b: $bytes-lib.bytes
        return:
          $result.result:
            t: $void
            e: $fs-error
    flush:
      $fn-type:
        args:
          $record:
            self: $self
        return:
          $result.result:
            t: $void
            e: $fs-error

appendable:
  $interface:
    append-string:
      $fn-type:
        args:
          $record:
            self: $self
            s: $str
        return:
          $result.result:
            t: $void
            e: $fs-error
    append-bytes:
      $fn-type:
        args:
          $record:
            self: $self
            b: $bytes-lib.bytes
        return:
          $result.result:
            t: $void
            e: $fs-error

closeable:
  $interface:
    close:
      $fn-type:
        args:
          $record:
            self: $self
        return:
          $result.result:
            t: $void
            e: $fs-error

read-file:
  $newtype: $uint64
  =impl:
    $readable:
      read-string:
        $function:
          args:
            self: $self
          return:
            $result.result:
              t: $str
              e: $fs-error
          do:
            - $wasm:
                import:
                  module: wasi_snapshot_preview1
                  name: fd_read
                args:
                  - $args.self
      read-bytes:
        $function:
          args:
            self: $self
          return:
            $result.result:
              t: $bytes-lib.bytes
              e: $fs-error
          do:
            - $wasm:
                import:
                  module: wasi_snapshot_preview1
                  name: fd_read
                args:
                  - $args.self
    $closeable:
      close:
        $function:
          args:
            self: $self
          return:
            $result.result:
              t: $void
              e: $fs-error
          do:
            - $wasm:
                import:
                  module: wasi_snapshot_preview1
                  name: fd_close
                args:
                  - $args.self

write-file:
  $newtype: $uint64
  =impl:
    $writable:
      write-string:
        $function:
          args:
            self: $self
            s: $str
          return:
            $result.result:
              t: $void
              e: $fs-error
          do:
            - $wasm:
                import:
                  module: wasi_snapshot_preview1
                  name: fd_write
                args:
                  - $args.self
                  - $args.s
      write-bytes:
        $function:
          args:
            self: $self
            b: $bytes-lib.bytes
          return:
            $result.result:
              t: $void
              e: $fs-error
          do:
            - $wasm:
                import:
                  module: wasi_snapshot_preview1
                  name: fd_write
                args:
                  - $args.self
                  - $args.b
      flush:
        $function:
          args:
            self: $self
          return:
            $result.result:
              t: $void
              e: $fs-error
          do:
            - $wasm:
                import:
                  module: wasi_snapshot_preview1
                  name: fd_sync
                args:
                  - $args.self
    $closeable:
      close:
        $function:
          args:
            self: $self
          return:
            $result.result:
              t: $void
              e: $fs-error
          do:
            - $wasm:
                import:
                  module: wasi_snapshot_preview1
                  name: fd_close
                args:
                  - $args.self

append-file:
  $newtype: $uint64
  =impl:
    $writable:
      write-string:
        $function:
          args:
            self: $self
            s: $str
          return:
            $result.result:
              t: $void
              e: $fs-error
          do:
            - $wasm:
                import:
                  module: wasi_snapshot_preview1
                  name: fd_write
                args:
                  - $args.self
