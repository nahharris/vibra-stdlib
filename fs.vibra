                import:
                  module: wasi_snapshot_preview1
                  name: fd_close
                args:
                  - $args.self

open-read:
  $function:
    args:
      p: $path
      grant: $security.fs-read-grant
    return:
      $result.result:
        t: $read-file
        e: $fs-error
    do:
      - $wasm:
          import:
            module: wasi_snapshot_preview1
            name: path_open
          args:
            - $args.p
            - $args.grant

open-write:
  $function:
    args:
      p: $path
      grant: $security.fs-write-grant
    return:
      $result.result:
        t: $write-file
        e: $fs-error
    do:
      - $wasm:
          import:
            module: wasi_snapshot_preview1
            name: path_open
          args:
            - $args.p
            - $args.grant

open-append:
  $function:
    args:
      p: $path
      grant: $security.fs-write-grant
    return:
      $result.result:
        t: $append-file
        e: $fs-error
    do:
      - $wasm:
          import:
            module: wasi_snapshot_preview1
            name: path_open
          args:
            - $args.p
            - $args.grant

open-read-write:
  $function:
    args:
      p: $path
      read-grant: $security.fs-read-grant
      write-grant: $security.fs-write-grant
    return:
      $result.result:
        t: $read-write-file
        e: $fs-error
    do:
      - $wasm:
          import:
            module: wasi_snapshot_preview1
            name: path_open
          args:
            - $args.p
            - $args.read-grant
            - $args.write-grant

narrow-read:
  $function:
    args:
      grant: $security.fs-read-grant
      p: $path
    return:
      $result.result:
        t: $security.fs-read-grant
        e: $fs-error
    do:
      - $wasm:
          import:
            module: wasi_snapshot_preview1
            name: grant_narrow_read
          args:
            - $args.grant
            - $args.p

narrow-write:
  $function:
    args:
      grant: $security.fs-write-grant
      p: $path
    return:
      $result.result:
        t: $security.fs-write-grant
        e: $fs-error
    do:
      - $wasm:
          import:
            module: wasi_snapshot_preview1
            name: grant_narrow_write
          args:
            - $args.grant
            - $args.p

read-to-string:
  $function:
    args:
      p: $path
      grant: $security.fs-read-grant
    return:
      $result.result:
        t: $str
        e: $fs-error
    do:
      - $wasm:
          import:
            module: wasi_snapshot_preview1
            name: read_to_string
          args:
            - $args.p
            - $args.grant

write-string-all:
  $function:
    args:
      p: $path
      s: $str
      grant: $security.fs-write-grant
    return:
      $result.result:
        t: $void
        e: $fs-error
    do:
      - $wasm:
          import:
            module: wasi_snapshot_preview1
            name: write_string_all
          args:
            - $args.p
            - $args.s
            - $args.grant

append-string:
  $function:
    args:
      p: $path
      s: $str
      grant: $security.fs-write-grant
    return:
      $result.result:
        t: $void
        e: $fs-error
    do:
      - $wasm:
          import:
            module: wasi_snapshot_preview1
            name: append_string
          args:
            - $args.p
            - $args.s
            - $args.grant

exists:
  $function:
    args:
      p: $path
      grant: $security.fs-read-grant
    return: $bool
    do:
      - $wasm:
          import:
            module: wasi_snapshot_preview1
            name: path_filestat_get
          args:
            - $args.p
            - $args.grant

create-dir-all:
  $function:
    args:
      p: $path
      grant: $security.fs-write-grant
    return:
      $result.result:
        t: $void
        e: $fs-error
    do:
      - $wasm:
          import:
            module: wasi_snapshot_preview1
            name: path_create_directory
          args:
            - $args.p
            - $args.grant

remove-file:
  $function:
    args:
      p: $path
      grant: $security.fs-write-grant
    return:
      $result.result:
        t: $void
