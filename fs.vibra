            - $args.grant

read-dir:
  $function:
    args:
      p: $path
      grant: $security.fs-read-grant
    return:
      $result.result:
        t:
          $array: $path
        e: $fs-error
    do:
      - $wasm:
          import:
            module: wasi_snapshot_preview1
            name: fd_readdir
          args:
            - $args.p
            - $args.grant

metadata:
  $function:
    args:
      p: $path
      grant: $security.fs-read-grant
    return:
      $result.result:
        t: $str
        e: $fs-error
    do:
      - $wasm:
          import:
            module: wasi_snapshot_preview1
            name: path_filestat_get
          args:
            - $args.p
            - $args.grant

canonicalize:
  $function:
    args:
      p: $path
      grant: $security.fs-read-grant
    return:
      $result.result:
        t: $path
        e: $fs-error
    do:
      - $wasm:
          import:
            module: wasi_snapshot_preview1
            name: path_filestat_get
          args:
            - $args.p
            - $args.grant
